# LabelHub Backend Configuration

# AI Provider: mock | dashscope | openai | deepseek
AI_PROVIDER=mock

# DashScope / Qwen Configuration
# Get your API key from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI Behavior
AI_TIMEOUT_SECONDS=25
AI_MOCK_FALLBACK=true
AI_FORCE_JSON=true

# Generic LLM Configuration (for OpenAI-compatible providers)
LLM_API_KEY=
LLM_API_BASE_URL=
AI_MODEL_NAME=

# Database
DATABASE_URL=sqlite:///./labelhub.db

# Security
SECRET_KEY=your-secret-key-change-in-production
